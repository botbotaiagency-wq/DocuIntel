# Database (required). Use a local Postgres or cloud URL.
# Local:  postgresql://postgres:postgres@localhost:5432/docuintel
# Supabase: Project Settings → Database → Connection string (URI). Use "Session mode" for Vercel.
#           Add ?sslmode=require if not present.
# Vercel + Supabase linked: POSTGRES_URL is set automatically; no need to set DATABASE_URL.
DATABASE_URL=

# Session secret (required). Use a long random string for production.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port for the server (default 5000)
PORT=5000

# Local development: use filesystem for document storage instead of Replit object storage.
# Set to 1 when running on localhost without Replit.
USE_LOCAL_STORAGE=1

# Optional: OpenAI for document extraction
# AI_INTEGRATIONS_OPENAI_API_KEY= or OPENAI_API_KEY=
# AI_INTEGRATIONS_OPENAI_BASE_URL= (optional; use for Azure or OpenAI-compatible proxies)
# EXTRACTION_MODEL= (default: gpt-4o). Use gpt-4o-mini for cheaper, or another vision model if base URL is set.

# Optional: rate limit for document export (PII) - per user or IP
# EXPORT_RATE_LIMIT_MAX=30
# EXPORT_RATE_LIMIT_WINDOW_MS=60000

# CORS: comma-separated allowed origins (e.g. https://app.example.com). Empty = no CORS restriction (dev).
# CORS_ORIGINS=
