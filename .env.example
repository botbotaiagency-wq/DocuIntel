# Database (required). Use a local Postgres or cloud URL.
# Example: postgresql://postgres:postgres@localhost:5432/docuintel
DATABASE_URL=

# Session secret (required). Use a long random string for production.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Port for the server (default 5000)
PORT=5000

# Local development: use filesystem for document storage instead of Replit object storage.
# Set to 1 when running on localhost without Replit.
USE_LOCAL_STORAGE=1

# Optional: OpenAI for document extraction (AI_INTEGRATIONS_OPENAI_API_KEY and AI_INTEGRATIONS_OPENAI_BASE_URL)
